---
layout: null
permalink: /sitemap.xml
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  {% for item in site.pages %}{% unless item.url contains '/404.html' or item.url contains '.json' or item.url contains '.xml' %}
  <url><loc>{{ item.url | absolute_url | xml_escape }}</loc>{% if item.last_modified_at %}<lastmod>{{ item.last_modified_at | date_to_xmlschema }}</lastmod>{% endif %}</url>
  {% endunless %}{% endfor %}
  {% for post in site.posts %}
  <url><loc>{{ post.url | absolute_url | xml_escape }}</loc><lastmod>{{ post.last_modified_at | default: post.date | date_to_xmlschema }}</lastmod></url>
  {% endfor %}
</urlset>
