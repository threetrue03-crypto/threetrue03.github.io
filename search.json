---
layout: null
permalink: /search.json
---
[
{% assign auto_news = site.data.tech_news %}
{% for post in site.posts %}
  {% capture search_text %}{{ post.title }} {{ post.description }} {{ post.category }} {{ post.tags | join: ' ' }} {{ post.content | strip_html }}{% endcapture %}
  {"title":{{ post.title | jsonify }},"description":{{ post.description | default: post.excerpt | strip_html | strip_newlines | jsonify }},"category":{{ post.category | jsonify }},"type":{{ post.type | default: 'note' | jsonify }},"url":{{ post.url | relative_url | jsonify }},"date":{{ post.date | date_to_xmlschema | jsonify }},"search":{{ search_text | strip_newlines | downcase | jsonify }}}{% unless forloop.last and auto_news.size == 0 %},{% endunless %}
{% endfor %}
{% for item in auto_news %}
  {% capture search_text %}{{ item.title }} {{ item.category }} {{ item.source }} 자동 수집 기술 뉴스{% endcapture %}
  {"title":{{ item.title | jsonify }},"description":{{ "자동 수집한 기술 뉴스" | jsonify }},"category":{{ item.category | jsonify }},"type":"news","url":{{ item.url | jsonify }},"date":{{ item.date | jsonify }},"search":{{ search_text | strip_newlines | downcase | jsonify }}}{% unless forloop.last %},{% endunless %}
{% endfor %}
]
