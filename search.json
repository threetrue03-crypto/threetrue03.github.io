---
layout: null
permalink: /search.json
---
[
{% for post in site.posts %}
  {% capture search_text %}{{ post.title }} {{ post.description }} {{ post.category }} {{ post.tags | join: ' ' }} {{ post.content | strip_html }}{% endcapture %}
  {"title":{{ post.title | jsonify }},"description":{{ post.description | default: post.excerpt | strip_html | strip_newlines | jsonify }},"category":{{ post.category | jsonify }},"type":{{ post.type | default: 'note' | jsonify }},"url":{{ post.url | relative_url | jsonify }},"date":{{ post.date | date_to_xmlschema | jsonify }},"search":{{ search_text | strip_newlines | downcase | jsonify }}}{% unless forloop.last %},{% endunless %}
{% endfor %}
]
